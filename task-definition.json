{
  "family": "hello-world-aws-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "taskRoleArn": "arn:aws:iam::213180001857:role/ecsTaskExecutionRole",
  "executionRoleArn": "arn:aws:iam::213180001857:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "hello-world-java",
      "image": "213180001857.dkr.ecr.us-east-2.amazonaws.com/curso-aws:latest",
      "portMappings": [
        {
          "containerPort": 8082,
          "hostPort": 8082,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hello-world-aws",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
